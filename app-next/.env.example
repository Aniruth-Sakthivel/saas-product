# Supabase — Dashboard → Project Settings → API
NEXT_PUBLIC_SUPABASE_URL="https://YOUR_PROJECT_REF.supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="your-anon-key"
SUPABASE_SERVICE_ROLE_KEY="your-service-role-key"

# Direct Postgres connection (for migrations / seed via supabase CLI)
# Project: hotel-management — password set in dashboard
SUPABASE_DB_URL="postgresql://postgres:[PASSWORD]@db.YOUR_PROJECT_REF.supabase.co:5432/postgres"

# Resend (transactional email) — https://resend.com/api-keys
RESEND_API_KEY="re_xxxxxxxx"
RESEND_FROM_EMAIL="HotelOS <noreply@yourdomain.com>"

# App
NEXT_PUBLIC_APP_URL="http://localhost:3000"
